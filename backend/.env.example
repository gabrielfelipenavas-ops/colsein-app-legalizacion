# File uploads
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=10485760

# Colsein defaults
COLSEIN_NIT=800002030
COLSEIN_NOMBRE=COLSEIN S.A.S.
TARIFA_CARRO=600.65
TARIFA_MOTO=507.03
