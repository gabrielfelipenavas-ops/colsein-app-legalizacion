PORT=3001
NODE_ENV=development

# PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_NAME=colsein_gastos
DB_USER=postgres
DB_PASS=postgres

# JWT
JWT_SECRET=colsein-jwt-secret-change-in-production-2026
